<Window x:Class="Lab_rab_2_6__CherevkoG.S_BPI_23_02.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab_rab_2_6__CherevkoG.S_BPI_23_02"
        mc:Ignorable="d"
        Title="Сравнение сортировок (Async/Task)"
        Height="750"
        Width="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="Размер массива:"
                       VerticalAlignment="Center"
                       Width="150"/>

                <TextBox Width="200"
                         Margin="5,0"
                         Text="{Binding ArraySize,
                                UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Сгенерировать"
                        Width="150"
                        Margin="10,0"
                        Command="{Binding GenerateArrayCommand}"/>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Margin="0,0,0,20"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       Text="{Binding OriginalArrayString}"/>

            <StackPanel Grid.Row="2" Margin="0,0,0,20">

                <TextBlock FontSize="16"
                           FontWeight="Bold"
                           Text="Пузырьковая сортировка"/>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Button Content="Запустить"
                            Width="130"
                            Margin="0,0,10,0"
                            Command="{Binding BubbleSortCommand}"/>

                    <Button Content="Отменить"
                            Width="130"
                            Background="LightCoral"
                            Command="{Binding CancelBubbleCommand}"/>
                </StackPanel>

                <ProgressBar Height="15" Minimum="0" Maximum="100" Margin="0,5" Value="{Binding BubbleProgress}"/>
                <TextBlock Text="{Binding BubblePreview}" Foreground="Gray" FontStyle="Italic" Margin="0,2"/>
                <TextBlock TextWrapping="Wrap" Text="{Binding BubbleSortResult}" FontWeight="SemiBold"/>

            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,20">

                <TextBlock FontSize="16"
                           FontWeight="Bold"
                           Text="Быстрая сортировка"/>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Button Content="Запустить"
                            Width="130"
                            Margin="0,0,10,0"
                            Command="{Binding QuickSortCommand}"/>

                    <Button Content="Отменить"
                            Width="130"
                            Background="LightCoral"
                            Command="{Binding CancelQuickCommand}"/>
                </StackPanel>

                <ProgressBar Height="20"
                             Minimum="0"
                             Maximum="100"
                             Margin="0,5"
                             Value="{Binding QuickProgress}"/>

                <TextBlock TextWrapping="Wrap"
                           Text="{Binding QuickSortResult}"/>

            </StackPanel>

            <StackPanel Grid.Row="4" Margin="0,0,0,20">

                <TextBlock FontSize="16"
                           FontWeight="Bold"
                           Text="Сортировка вставками"/>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Button Content="Запустить"
                            Width="130"
                            Margin="0,0,10,0"
                            Command="{Binding InsertionSortCommand}"/>

                    <Button Content="Отменить"
                            Width="130"
                            Background="LightCoral"
                            Command="{Binding CancelInsertionCommand}"/>
                </StackPanel>

                <ProgressBar Height="20"
                             Minimum="0"
                             Maximum="100"
                             Margin="0,5"
                             Value="{Binding InsertionProgress}"/>

                <TextBlock TextWrapping="Wrap"
                           Text="{Binding InsertionSortResult}"/>

            </StackPanel>

            <StackPanel Grid.Row="5" Margin="0,0,0,20">

                <TextBlock FontSize="16"
                           FontWeight="Bold"
                           Text="Пирамидальная сортировка"/>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Button Content="Запустить"
                            Width="130"
                            Margin="0,0,10,0"
                            Command="{Binding HeapSortCommand}"/>

                    <Button Content="Отменить"
                            Width="130"
                            Background="LightCoral"
                            Command="{Binding CancelHeapCommand}"/>
                </StackPanel>

                <ProgressBar Height="20"
                             Minimum="0"
                             Maximum="100"
                             Margin="0,5"
                             Value="{Binding HeapProgress}"/>

                <TextBlock TextWrapping="Wrap"
                           Text="{Binding HeapSortResult}"/>

            </StackPanel>

            <TextBlock Grid.Row="6"
                       Margin="0,20,0,10"
                       FontSize="16"
                       FontWeight="Bold"
                       Text="{Binding TotalComparisons}"/>
            <StackPanel Grid.Row="7" Margin="0,0,0,20">
                <Button
                        Height="40"
                        Margin="0,1"
                        Background="IndianRed"
                        Foreground="White"
                        FontWeight="Bold"
                        Content="ОТМЕНИТЬ ВСЕ СОРТИРОВКИ"
                        Command="{Binding CancelAllCommand}"/>
                <Button Content="Запустить всё"
                        Height="40"
                        Margin="0,1"
                        Background="LightGreen"
                        Command="{Binding SortAllCommand}"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>